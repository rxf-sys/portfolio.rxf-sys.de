[
  {
    "id": "deploy-portfolio",
    "execute-command": "/opt/portfolio/deploy.sh",
    "command-working-directory": "/var/www/portfolio",
    "pass-arguments-to-command": [],
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "HIER_WEBHOOK_SECRET_EINSETZEN",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
